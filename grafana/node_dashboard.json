      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "CPU speed ",
          "description": "CPU’s working in cycles and we can measure. The node exporter exposes how many cycles per seconds the CPU works at, also known as Hertz. We get the average number of cycles per second it runs by, then divide it by 1,000,000,000 to get the unit of Giga Hertz, the normal unit of measurement for CPU speed.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "dfjs9wo7l6ubkc"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "avg(node_cpu_scaling_frequency_hertz) / 1000000000",
                        "legendFormat": "__auto",
                        "range": true
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
