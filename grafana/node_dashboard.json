      "panel-9": {
        "kind": "Panel",
        "spec": {
          "id": 9,
          "title": "Power Usage",
          "description": "Linux has a subsystem called RAPL that deals with directly accessing the cpu to find out it's energy consumption in terms of joules. To convert the metric to watts, the normal unit of measurement for power consumption, we got the rate of joules that were being spent over a 5-minute interval. We found that power was being drawn from two sockets (2 different CPU chips) so, we summed them up to find the total power usage for the CPU.\n",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "dfjs9wo7l6ubkc"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum(rate(node_rapl_package_joules_total[5m]))",
                        "legendFormat": "__auto",
                        "range": true
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
