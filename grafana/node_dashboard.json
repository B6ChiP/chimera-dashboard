      "panel-8": {
        "kind": "Panel",
        "spec": {
          "id": 8,
          "title": "User vs System vs Idle vs IO Wait",
          "description": "This chart shows the relationship between user level processes and system level processes. You will notice that the yellow line (system processes) is always higher than the green line (user processes). This detail is expected because we assume that system level processes generally take more power to perform than user level ones. We also see that the general shape of the lines match. This pattern also makes sense because whenever an application is run, background processes (daemons) are needed to maintain optimal conditions for the user level process to run.\nOn a security perspective, this graph shows the relationship between these two processes. Because we assume that the shapes of these two lines should generally match, we can also detect anomalies when they don't. Suppose that suddenly the yellow line spikes while the green line stays the same. That spike suggests an anomaly in the system worth investigating. One plausible possibility is that someone illegally escalated privileges, causing system level processes to spike. Just from a sudden spike we cannot directly discern the cause, but it is worth noting.\n",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
