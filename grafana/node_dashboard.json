      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "CPU usage ",
          "description": "The node exporter exposes the time the CPU spends idle (not doing anything) at any given second. We get all the times it spends idle over a 5 minute interval then average them out. This calculation alone gives us a percentage of the time the CPU does nothing, the opposite of what we want to find. Therefore, we simply subtract that percentage from 100 to find out the time the CPU is actually doing work which gives us the final CPU usage percentage.\n",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "dfjs9wo7l6ubkc"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
                        "legendFormat": "__auto",
                        "range": true
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "13.0.1",
            "spec": {
              "options": {
                "colorMode": "background",
